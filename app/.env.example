MONGODB_URI=mongodb://localhost:27018/xero_time?replicaSet=xero_time_rs0&directConnection=true
MONGODB_MAX_POOL_SIZE=10
PAYLOAD_SECRET=generate-with-openssl-rand-hex-32
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
APP_ENVIRONMENT=development
APP_RELEASE=local
ERROR_MONITORING_DSN=

# Keep manual for local setup. Use resend only after the sender domain and API key are ready.
ACCOUNT_EMAIL_DELIVERY_MODE=manual
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
RESEND_FROM_NAME=Project Time

# Required only when optional Xero identity login is configured.
AUTH_FLOW_ENCRYPTION_KEY=
AUTH_FLOW_ENCRYPTION_KEY_VERSION=1

# Xero identity login (openid profile email only)
XERO_IDENTITY_CLIENT_ID=
XERO_IDENTITY_CLIENT_SECRET=
XERO_IDENTITY_REDIRECT_URI=http://localhost:3000/api/auth/xero/identity/callback

# The Xero accounting OAuth app is configured by an owner/admin inside the application.
# This optional value verifies Xero webhook signatures after webhooks are enabled.
XERO_WEBHOOK_KEY=

# Machine-only bearer secret used by the one-minute Xero queue runner.
CRON_SECRET=

# Optional non-interactive alternative to the one-time first-user Admin form.
# Remove these values immediately after running pnpm seed:owner.
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_NAME=
SEED_OWNER_TIMEZONE=Pacific/Auckland
